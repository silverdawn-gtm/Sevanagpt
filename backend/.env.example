# =============================================================================
# SevanaGPT Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# -- Database (PostgreSQL + pgvector) ----------------------------------------
DATABASE_URL=postgresql+asyncpg://myscheme:myscheme_dev@localhost:5433/myscheme
DATABASE_URL_SYNC=postgresql://myscheme:myscheme_dev@localhost:5433/myscheme

# -- Mistral AI (chat + embeddings) ------------------------------------------
# Get key at: https://console.mistral.ai
MISTRAL_API_KEY=

# -- Groq (free LLM fallback) ------------------------------------------------
# Get key at: https://console.groq.com
GROQ_API_KEY=

# -- IndicTrans2 (local translation microservice) ----------------------------
# Run via Docker:  docker compose up -d indictrans
# Or locally:      cd indictrans && uvicorn app.main:app --port 7860
INDICTRANS_URL=http://localhost:7860

# -- MyScheme.gov.in API (scheme ingestion) ----------------------------------
# Public web key from myscheme.gov.in; the code falls back to it if unset.
MYSCHEME_API_KEY=

# -- Kaggle (dataset ingestion) ----------------------------------------------
# Get credentials at: https://www.kaggle.com/settings
KAGGLE_USERNAME=
KAGGLE_KEY=

# -- Data.gov.in (dataset ingestion) -----------------------------------------
# Get key at: https://data.gov.in/
DATAGOV_API_KEY=
