# SevanaGPT IndicTrans2 Microservice — Environment Variables

# HuggingFace token for the gated ai4bharat/indictrans2 model.
# Needs "read" access to public gated repos. Under Docker Compose this is
# supplied via the repo-root .env (HF_TOKEN) at runtime, not here.
HF_TOKEN=

# Optional LoRA adapter directory (domain fine-tuned weights). Leave unset for base model.
INDICTRANS_LORA_ADAPTER_PATH=

# Device selection: auto-detects cuda/cpu when unset.
INDICTRANS_DEVICE=

# Generation tuning (defaults shown; tuned for ~6GB VRAM).
INDICTRANS_MAX_BATCH_SIZE=4
INDICTRANS_MAX_LENGTH=256
INDICTRANS_NUM_BEAMS=1
