# =============================================================================
# Root env — read by docker-compose variable interpolation (${VAR}).
# Copy to .env at the repo root:  cp .env.example .env
# =============================================================================

# HuggingFace token for the gated ai4bharat/indictrans2 model.
# Needs "read" access to public gated repos. Supplied to the indictrans
# service at runtime (never baked into the image).
HF_TOKEN=
